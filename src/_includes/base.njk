<!doctype html>
<html lang="{{ lang | default('de') }}">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title }}</title>
<meta name="robots" content="index, follow" />
  <meta name="description" content="{{ description or i18n["meta.description"][lang] }}" />
  <link rel="canonical" href="https://www.aeternus-verlag.de/{{ lang }}/" />
  <link rel="alternate" hreflang="de" href="https://www.aeternus-verlag.de/de/" />
  <link rel="alternate" hreflang="en" href="https://www.aeternus-verlag.de/en/" />
  <link rel="alternate" hreflang="x-default" href="https://www.aeternus-verlag.de/de/" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="{{ i18n["meta.title"][lang] }}" />
  <meta property="og:description" content="{{ i18n["meta.description"][lang] }}" />
  <meta property="og:url" content="https://www.aeternus-verlag.de/{{ lang }}/" />
  <meta property="og:site_name" content="Aeternus Verlag" />
  <meta property="og:locale" content="{% if lang == 'de' %}de_DE{% else %}en_US{% endif %}" />
  <meta property="og:image" content="https://www.aeternus-verlag.de/assets/images/og-share-cover.jpg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
{% include 'header.njk' %}
   {{content | safe}} 
{% include 'footer.njk' %}
<script>
  // Cursor-tracked glow on category tiles
  document.getElementById('catGrid')?.addEventListener('mousemove', (e) => {
    const tile = e.target.closest('[data-tile]');
    if (!tile) return;
    const r = tile.getBoundingClientRect();
    tile.style.setProperty('--mx', (e.clientX - r.left) + 'px');
    tile.style.setProperty('--my', (e.clientY - r.top) + 'px');
  });

 <!-- Language Switching Engine -->
function switchLanguage(lang, button) {
            // Update active state class on buttons
            document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');
            
            // Loop through and swap text contents based on target data-attributes
            document.querySelectorAll('[data-de]').forEach(element => {
                if (lang === 'en') {
                    element.textContent = element.getAttribute('data-en');
                } else {
                    element.textContent = element.getAttribute('data-de');
                }
            });
            
   // Adjust semantic document locale tag
            document.documentElement.lang = lang;
        }


</script>

<script>
//smooth language page convert
  function initAeternusRouter() {
    // ---- 1. HANDLE EXTERNAL/INTERNAL LINK CLICKING ----
    document.body.addEventListener('click', async (e) => {
      // Find closest anchor tag clicked anywhere on the page
      const link = e.target.closest('a');
      if (!link) return;

      const href = link.getAttribute('href');
      if (!href) return;

      // RULE A: If it's purely a hash link on the SAME page (e.g., href="#catalog")
      if (href.startsWith('#')) {
        // Only run if we aren't changing languages
        if (!link.closest('.lang-switch')) {
          e.preventDefault();
          const targetElement = document.querySelector(href);
          if (targetElement) {
            targetElement.scrollIntoView({ behavior: 'smooth' });
            // Update URL hash smoothly without breaking page history
            history.pushState(null, '', href);
          }
          return;
        }
      }

      // RULE B: If it's a language switcher link (e.g., href="/" or href="/en/")
      if (link.closest('.lang-switch')) {
        e.preventDefault();
        const targetUrl = href;
        
        if (link.classList.contains('is-active')) return;

        try {
          const response = await fetch(targetUrl);
          if (!response.ok) throw new Error('Fetch failed');
          const htmlText = await response.text();
          
          const parser = new DOMParser();
          const newDoc = parser.parseFromString(htmlText, 'text/html');
          
          // Swap Navigation Menu Link Text
          const currentNav = document.querySelector('nav.primary');
          const newNav = newDoc.querySelector('nav.primary');
          if (currentNav && newNav) currentNav.innerHTML = newNav.innerHTML;

          // Swap Header Action Buttons
          const currentActions = document.querySelector('.header-actions');
          const newActions = newDoc.querySelector('.header-actions');
          if (currentActions && newActions) currentActions.innerHTML = newActions.innerHTML;

          // Swap Main Page Content
          const currentMain = document.querySelector('main');
          const newMain = newDoc.querySelector('main');
          if (currentMain && newMain) currentMain.innerHTML = newMain.innerHTML;

          // === FIX FOR FOOTER LANGUAGE CHANGE ===
          // Looks for the layout site footer and updates its content
          const currentFooter = document.querySelector('footer.site');
          const newFooter = newDoc.querySelector('footer.site');
          if (currentFooter && newFooter) currentFooter.innerHTML = newFooter.innerHTML;

          // Swap Switcher Active States
          const currentSwitch = document.querySelector('.lang-switch');
          const newSwitch = newDoc.querySelector('.lang-switch');
          if (currentSwitch && newSwitch) currentSwitch.innerHTML = newSwitch.innerHTML;
          
          // Update URL and Lang Attributes
          history.pushState(null, '', targetUrl);
          document.documentElement.lang = newDoc.documentElement.lang || 'de';
          
          // Reset viewport position to the very top on language toggle
          window.scrollTo({ top: 0, behavior: 'smooth' });

        } catch (error) {
          console.warn('[Router] Redirecting via fallback:', error);
          window.location.href = targetUrl;
        }
      }
    });

    // ---- 2. HANDLE BACK/FORWARD SYSTEM BUTTONS ----
    window.addEventListener('popstate', () => {
      window.location.reload();
    });
  }

  // Initialize script safely
  document.addEventListener('DOMContentLoaded', initAeternusRouter);
  if (document.readyState === 'interactive' || document.readyState === 'complete') {
    initAeternusRouter();
  }
</script>
</body>
</html>